        NotInRange: "&cSeu parceiro(a) não está próximo! Vocês precisam estar a no máximo {Range} blocos de distância!"
    Economy:
      NotEnough: "&cVocê não tem dinheiro suficiente! Você precisa de {Cost} {CurrencyName} para isso."
      PartnerNotEnough: "&cSeu parceiro(a) não tem dinheiro suficiente!"
      PriestMarryNotEnough: "&cOs jogadores que você está tentando casar não têm dinheiro suficiente."
      PriestDivorceNotEnough: "&cOs jogadores que você está tentando divorciar não têm dinheiro suficiente."
      MarriagePaid: "&aVocê pagou {Cost} {CurrencyName} pelo seu casamento (restam {Remaining} {CurrencyName})."
      DivorcePaid: "&aVocê pagou {Cost} {CurrencyName} pela anulação do seu casamento (restam {Remaining} {CurrencyName})."
      HomeTPPaid: "&aVocê pagou {Cost} {CurrencyName} pelo teleporte para casa (restam {Remaining} {CurrencyName})."
      SetHomePaid: "&aVocê pagou {Cost} {CurrencyName} para definir sua casa (restam {Remaining} {CurrencyName})."
      TpPaid: "&aVocê pagou {Cost} {CurrencyName} pelo teleporte (restam {Remaining} {CurrencyName})."
      GiftPaid: "&aVocê pagou {Cost} {CurrencyName} por presentear um item ao seu parceiro(a) (restam {Remaining} {CurrencyName})."
      SurnameChangePaid: "&aVocê pagou {Cost} {CurrencyName} para mudar um sobrenome (restam {Remaining} {CurrencyName})."
    Admin:
      Reloading: "&1aguarde um instante!"
      Reloaded: "&1Recarregado!"
      ReloadingDatabase: "&bRecarregando banco de dados &6.&r&c.&r&a.&r"
      CheckingForUpdates: "&1Procurando por atualizações..."
      Updated: "&ePlugin atualizado, será carregado na próxima reinicialização/reload."
      NoUpdate: "&6Nenhuma atualização disponível."
      UpdateFail: "&cOcorreu um problema ao procurar por atualizações! Por favor, verifique o console!"
      # You can change this message if you like to, but don't cry if the link isn't linking to the plugin anymore!
      UpdateAvailable: "[{\"text\":\"Há uma atualização disponível! Por favor, acesse \\\"\",\"color\":\"green\"},{\"text\":\"https://www.spigotmc.org/resources/marriage-master-mc-1-7-1-9.19273/\",\"color\":\"yellow\",\"underlined\":true,\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.spigotmc.org/resources/marriage-master-mc-1-7-1-9.19273/\"}},{\"text\":\"\\\" para baixar!\"}]"
    Help:
      Header: "&6### Comandos Marriage Master ###"
      Footer: "&6##############################"
      # Allows you to define messages that should be sent if the player uses the "/marry" command without any parameters (HelpMode must be set to CustomHelp in the config)
      CustomHelp:
        # Will be used if the player is married
        Married:
          - " &3__&b&lComandos Marry&r&3__"
          - ""
          - '[{"text":" ➤ ","color":"white"},{"text":"/marry kiss","color":"dark_aqua","bold":true,"underlined":true,"clickEvent":{"action":"run_command","value":"/marry kiss"}},{"text":" beijar seu parceiro(a)","color":"aqua"}]'
          - '[{"text":" ➤ ","color":"yellow"},{"text":"/marry tp","color":"dark_aqua","bold":true,"underlined":true,"clickEvent":{"action":"run_command","value":"/marry tp"}},{"text":" teleportar para seu parceiro(a)","color":"aqua"}]'
          - '[{"text":" ➤ ","color":"gold"},{"text":"/marry chat toggle","color":"dark_aqua","bold":true,"underlined":true,"clickEvent":{"action":"run_command","value":"/marry chat toggle"}},{"text":" conversar em privado com seu parceiro(a)","color":"aqua"}]'
          - '[{"text":" ➤ ","color":"gold"},{"text":"/marry gift","color":"dark_aqua","bold":true,"underlined":true,"clickEvent":{"action":"run_command","value":"/marry gift"}},{"text":" presentear seu parceiro(a)","color":"aqua"}]'
          - '[{"text":"Use ","color":"dark_green"},{"text":"/marry help","color":"dark_aqua","bold":true},{"text":" para a lista completa de comandos"}]'
        # Will be used if the player is a priest
        Priest:
          - " &3__&b&lCasamento&r&3__"
          - "&b Você pode casar jogadores usando /marry marry <jogador1> <jogador2>"
          - '[{"text":"Use ","color":"dark_green"},{"text":"/marry help","color":"dark_aqua","bold":true},{"text":" para a lista completa de comandos"}]'
        # Will be used if the player is neither married nor a priest
        Default:
          - " &3__&b&lCasamento&r&3__"
          - "&cVocê precisa estar casado(a) para usar este comando"

  Commands:
    HelpFormat: '["",{"text":"/{MainCommand} {SubCommand} {Parameters}","clickEvent":{"action":"suggest_command","value":"/{MainCommand} {SubCommand}"}},{"text":" - ","color":"white"},{"text":"{Description}","color":"aqua"}]'
    # No color codes please
    PlayerNameVariable: "jogador"
    PartnerNameVariable: "parceiro"
    SurnameVariable: "sobrenome"
    MessageVariable: "mensagem"
    Description:
      Backpack: "Abre a mochila do seu parceiro(a)."
      BackpackOn: "Permite que seu parceiro(a) use sua mochila."
      BackpackOff: "Impede que seu parceiro(a) use sua mochila."
      Chat: "Chat privado com seu parceiro(a)."
      ChatSetTarget: "Muda o alvo da mensagem privada."
      ChatToggle: "Alterna seu chat para o privado com seu parceiro(a)."
      ChatListen: "Mostra todas as mensagens de chat enviadas por jogadores casados."
      Gift: "Presenteia seu parceiro(a) com o item em sua mão."
      Home: "Teleporta você para sua casa."
      HomeOther: "Teleporta você para a casa de um jogador casado."
      SetHome: "Define sua casa."
      SetHomeOther: "Define a casa de um jogador casado."
      DelHome: "Deleta sua casa."
      DelHomeOther: "Deleta a casa de um jogador casado."
      Help: "Mostra todos os comandos disponíveis e suas descrições."
      List: "Lista todos os jogadores casados."
      ListPriests: "Lista todos os padres online."
      Partners: "Lista todos os parceiros de um jogador."
      PvP: "Muda o status do PvP com o parceiro(a)."
      PvPOn: "Ativa o PvP com o parceiro(a)."
      PvPOff: "Desativa o PvP com o parceiro(a)."
      Tp: "Teleporta você para seu parceiro(a)."
      Kiss: "Você beija seu parceiro(a)."
      Hug: "Você abraça seu parceiro(a)."
      Seen: "Mostra quando seu parceiro(a) esteve online pela última vez."
      Marry: "Casa dois jogadores."
      MarrySelf: "Envia um pedido de casamento para outro jogador."
      Divorce: "Divorcia dois jogadores."
      DivorceSelf: "Para se separar do seu parceiro(a)."
      Surname: "Muda o sobrenome de um casal."
      SurnameSelf: "Muda o seu sobrenome e do seu parceiro(a)."
      Update: "Verifica se há uma atualização e a baixa."
      Accept: "Aceita um pedido pendente."
      Cancel: "Cancela um pedido pendente."
      Deny: "Nega um pedido pendente."
      SetColor: "Define a cor do casamento."
      SetPriest: "Promove/Rebaixa um jogador a padre."
      Reload: "Recarrega a configuração do plugin."
      Version: "Mostra os detalhes da versão do plugin e suas dependências."
