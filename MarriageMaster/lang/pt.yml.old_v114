# To simplify the customisation and the translation process please check out the editor: https://ptp.pcgamingfreaks.at
Language:
  NotFromConsole: "&cEste comando não pode ser usado pelo cmd!"
  # Global Wildcards: <heart> and <smallheart>
  Ingame:
    NoPermission: "&cVocê não tem permissão para fazer isso."
    NaN: "&cO valor inserido não é um número!"
    NotMarried: "&cVocê não é casado(a)."
    PartnerOffline: "&cSeu parceiro(a) está offline."
    PartnerNotInRange: "&cSeu parceiro(a) está muito longe."
    TargetPartnerNotFound: "&cSeu parceiro(a) alvo não foi encontrado!"
    PlayerNotMarried: '&c"{PlayerName}" não é casado(a)!'
    PlayerNotFound: '&cNão foi possível encontrar "{PlayerName}"!'
    PlayerNotOnline: '&c"{PlayerName}" está offline!'
    PlayersNotMarried: "&cOs jogadores não são casados!"
    MarriageNotExact: "&cDesculpe, mas há mais de um casamento correspondente à sua solicitação!"
    JoinLeaveInfo:
      # Only used for players with 1 partner
      PartnerOnline: "&aSeu amor(a) está online."
      # Only used for players with 1 partner
      PartnerOffline: "&7Seu amor(a) está offline."
      # Only used for players with more than 1 partner
      AllPartnersOffline: "&7Todos os seus parceiros(as) estão offline."
      # Only used for players with more than 1 partner
      PartnerOnlineMulti: "&aOs seguintes parceiros(as) estão online: &r&f{OnlinePartners}"
      # Placeholders: {Name}, {DisplayName}.    Keep in mind display names can contain colors!  No JSON!!!
      MultiOnlineFormat: "{DisplayName}"
      # No JSON!!!
      MultiOnlineSeparator: "&r, "
      # Placeholders: {Name}, {DisplayName}
      PartnerNowOnline: "&aSeu parceiro(a) está online agora."
      # Placeholders: {Name}, {DisplayName}
      PartnerNowOffline: "&7Seu parceiro(a) está offline agora."
    Backpack:
      OnlyInSurvival: "&cVocê só pode acessar a mochila do seu parceiro(a) no modo sobrevivência."
      ShareOn: "&aVocê agora compartilha sua mochila com seu parceiro(a)."
      ShareOff: "&cVocê não está mais compartilhando sua mochila com seu parceiro(a)."
      Opened: "&aSeu parceiro(a) abriu sua mochila."
      ShareDenied: "&cSeu parceiro(a) não lhe deu acesso à mochila dele(a)."
    Chat:
      Joined: "&aVocê definiu seu chat para o chat privado de casamento."
      Left: "&aVocê definiu seu chat para o chat público."
      ListeningStarted: "&aVocê agora está espionando o chat de casamento."
      ListeningStopped: "&aVocê não está mais espionando o chat de casamento."
      TargetSet: "&aAlvo do chat privado definido."
      DisplayNameAll: "Todos os Parceiros"
      # Placeholders: {SenderDisplayName}, {SenderName}, {ReceiverDisplayName}, {ReceiverName}, {Message}, {MagicHeart}
      Format: "{MagicHeart}&r {SenderDisplayName}&r&6 => &r{ReceiverDisplayName}&r&f: &r{Message}"
    Gift:
      # Placeholders: {AllowedGameModes}, {CurrentGameMode}
      GameModeNotAllowedSender: "&cVocê não pode enviar presentes no seu modo de jogo atual."
      # Placeholders: {AllowedGameModes}, {CurrentGameMode}
      GameModeNotAllowedReceiver: "&cSeu parceiro(a) não pode receber presentes no modo de jogo atual dele(a)."
      NoItemInHand: "&cVocê não está segurando um item."
      PartnerInvFull: "&cO inventário do seu parceiro(a) está cheio."
      # Placeholders: {Name}, {DisplayName}, {ItemAmount}, {ItemName}, {ItemMetaJSON} = Item as JSON for hover event
      ItemSent: '[{"text":"Você enviou para seu parceiro(a) ","color":"green"},{"text":"{ItemAmount} {ItemName}","hoverEvent":{"action":"show_item","value":"{ItemMetaJSON}"}},{"text":"."}]'
      # Placeholders: {Name}, {DisplayName}, {ItemAmount}, {ItemName}, {ItemMetaJSON} = Item as JSON for hover event
      ItemReceived: '[{"text":"Seu ","color":"green"},{"text":"parceiro(a)","hoverEvent":{"action":"show_text","value":"{DisplayName}"}},{"text":" lhe enviou "},{"text":"{ItemAmount} {ItemName}","hoverEvent":{"action":"show_item","value":"{ItemMetaJSON}"}},{"text":"."}]'
      WorldNotAllowed: "&cSeu parceiro(a) está em um mundo onde não é permitido receber presentes."
      ItemNotAllowed: "&cVocê não tem permissão para presentear seu parceiro(a) com {ItemName}&c!"
      # Placeholders: {ItemAmount}, {ItemName}, {ItemMetaJSON} = Item as JSON for hover event
      Request:
        Notification: '["",{"text":"{DisplayName}&r quer te presentear com "},{"text":"{ItemAmount} {ItemName}","hoverEvent":{"action":"show_item","value":"{ItemMetaJSON}"}},{"text":". Aceite o presente com "},{"text":"/marry accept","color":"green","underlined":true,"clickEvent":{"action":"run_command","value":"/marry accept"}},{"text":" ou negue com "},{"text":"/marry deny","color":"red","underlined":true,"clickEvent":{"action":"run_command","value":"/marry deny"}},{"text":"."}]'
        WaitForConfirmation: "Pedido de presente enviado ao seu parceiro(a)."
        Denied: "Você negou o presente do seu parceiro(a)."
        DeniedPartner: "Seu parceiro(a) negou o presente. Seu item foi devolvido."
        Canceled: "Você cancelou seu pedido de presente."
        CanceledPartner: "Seu parceiro(a) cancelou o pedido de presente. Seu item foi devolvido."
        CanceledDisconnectRequester: "Seu parceiro(a) ficou offline. Pedido de presente cancelado. Seu item foi devolvido."
        CanceledDisconnectTarget: "Seu parceiro(a) ficou offline. Pedido de presente cancelado."
        RefundInvFull: "&cSeu inventário está cheio, os itens restantes do presente foram dropados no chão!"
        PartnerAlreadyHasAnOpenRequest: "&cSeu parceiro(a) já tem um pedido em aberto. Por favor, espere que ele(a) aceite ou negue primeiro."
    Home:
      Deleted: "&aCasa deletada com sucesso."
      PlayerNoHome: "&cO jogador ainda não tem uma casa."
      NoHome: "&cVocê ainda não tem uma casa."
      TPed: "&aVocê foi teleportado para sua casa."
      Set: "&aCasa salva com sucesso."
      BlockedFrom: "&cVocê não pode se teleportar para casa a partir daqui."
      BlockedTo: "&cVocê não pode se teleportar para sua casa. Por favor, mude-a de lugar."
    Kiss:
      Kissed: "&eVocê beijou seu parceiro(a)!"
      Kissed_SendMethod: "action_bar"
      GotKissed: "&eSeu parceiro(a) te beijou!"
      GotKissed_SendMethod: "action_bar"
      TooFarAway: "&cVocê está muito longe para beijar seu parceiro(a). (Máx. {Distance} blocos)"
      # Placeholders: {Time}, {TimeLeft} in seconds
      Wait: "&cVocê precisa esperar {Time} segundos para beijar seu parceiro(a) novamente."
    Hug:
      Hugged: "&eVocê abraçou seu parceiro(a)!"
      Hugged_SendMethod: "action_bar"
      GotHugged: "&eSeu parceiro(a) te abraçou!"
      GotHugged_SendMethod: "action_bar"
      TooFarAway: "&cVocê está muito longe para abraçar seu parceiro(a). (Máx. {Distance} blocos)"
      # Placeholders: {Time}, {TimeLeft} in seconds
      Wait: "&cVocê precisa esperar {Time} segundos para abraçar seu parceiro(a) novamente."
    Seen:
      # Placeholders: {Name}, {DisplayName}
      CurrentlyOnline: "{DisplayName}&r está &aonline&r."
      # Placeholders: {Name}, {Date}, {Count}, {CountTotalDays}
      LastSeen: '["",{"text":"{Name} foi visto pela última vez em ","extra":[{"text":"{Date}","hoverEvent":{"action":"show_text","value":"{Count} atrás"}},{"text":"."}]}]'
      # No Json!!!
      DateFormat: "dd-MM-yyyy 'às' HH:mm:ss"
    List:
      # Placeholders: {Player1Name}, {Player1DisplayName}, {Player2Name}, {Player2DisplayName}, {Surname}, {MagicHeart}
      Format: "&2{Player1DisplayName} {MagicHeart} &2{Player2DisplayName}"
      NoMarriedPlayers: "&cNão há jogadores casados."
      Headline: "&eLista de jogadores casados&r&f - &r&6mostrando página {CurrentPage}/{MaxPage}"
      Footer: '["",{"text":"<<< Anterior <<<","color":"gray","clickEvent":{"action":"run_command","value":"/{MainCommand} {SubCommand} {PrevPage}"},"hoverEvent":{"action":"show_text","value":"/{MainCommand} {SubCommand} {PrevPage}"}},{"text":" Mostrando página {CurrentPage}/{MaxPage} ","color":"gold"},{"text":">>> Próxima >>>","color":"gray","clickEvent":{"action":"run_command","value":"/{MainCommand} {SubCommand} {NextPage}"},"hoverEvent":{"action":"show_text","value":"/{MainCommand} {SubCommand} {NextPage}"}}]'
    Partners:
      Headline: "&eLista de parceiros de {DisplayName}:"
      Footer: "&e################################"
      NotMarried: "{DisplayName}&e não é casado(a)."
      # Player1 is the player that was queried. Player2 is the partner
      Format: "&2{Player1DisplayName} {MagicHeart} &2{Player2DisplayName}"
    ListPriests:
      Format: "&2{PriestDisplayName}"
      NoPriestsOnline: "&cNão há padres online."
      Headline: "&ePadres online&r&f - &r&6mostrando página {CurrentPage}/{MaxPage}"
      Footer: '["",{"text":"<<< Anterior <<<","color":"gray","clickEvent":{"action":"run_command","value":"/{MainCommand} {SubCommand} {PrevPage}"},"hoverEvent":{"action":"show_text","value":"/{MainCommand} {SubCommand} {PrevPage}"}},{"text":" Mostrando página {CurrentPage}/{MaxPage} ","color":"gold"},{"text":">>> Próxima >>>","color":"gray","clickEvent":{"action":"run_command","value":"/{MainCommand} {SubCommand} {NextPage}"},"hoverEvent":{"action":"show_text","value":"/{MainCommand} {SubCommand} {NextPage}"}}]'
    PvP:
      IsDisabled: "&cVocê não pode ferir seu parceiro(a) se o PvP estiver desativado."
      IsDisabled_SendMethod: "action_bar"
      On: "&aVocê ativou o PvP com seu parceiro(a)."
      Off: "&aVocê desativou o PvP com seu parceiro(a)."
    TP:
      PartnerVanished: "&cVocê não pode se teleportar se seu parceiro(a) estiver invisível."
      Teleport: "&aTeleportando para seu parceiro(a)..."
      TeleportTo: "&aSeu parceiro(a) está se teleportando para você..."
      Unsafe: "&cTeleporte cancelado! Você não sobreviveria!"
      ToUnsafe: "&cSeu parceiro(a) estava prestes a se teleportar para você, mas não sobreviveria!"
      WorldNotAllowed: "&cSeu parceiro(a) está em um mundo onde o teleporte não é permitido."
      Moved: "&cTeleporte cancelado! Você se moveu!"
      DontMove: "&cTeleporte em {Time} seg! Não se mova!"
      BlockedFrom: "&cVocê não pode se teleportar para seu parceiro(a) a partir daqui."
      BlockedTo: "&cVocê não pode se teleportar para onde seu parceiro(a) está."
      Request:
        Notification: '["",{"text":"{DisplayName}&r quer se teleportar para você. Aceite com "},{"text":"/marry accept","color":"green","underlined":true,"clickEvent":{"action":"run_command","value":"/marry accept"}},{"text":" ou negue com "},{"text":"/marry deny","color":"red","underlined":true,"clickEvent":{"action":"run_command","value":"/marry deny"}},{"text":"."}]'
        WaitForConfirmation: "Por favor, espere até que seu parceiro(a) aceite o teleporte."
        Denied: "Você negou o pedido de teleporte do seu parceiro(a)."
        DeniedPartner: "Seu parceiro(a) negou o pedido de teleporte."
        Canceled: "Você cancelou seu pedido de teleporte."
        CanceledPartner: "Seu parceiro(a) cancelou o pedido de teleporte."
        CanceledDisconnectRequester: "Seu parceiro(a) ficou offline. Pedido de teleporte cancelado."
        CanceledDisconnectTarget: "Seu parceiro(a) ficou offline. Pedido de teleporte cancelado."
    SetColor:
      UnknownColor: "&cNão foi possível identificar a cor '{Input}'!"
      Set: "Cor definida."
      Selection: '["",{"text":"Por favor, clique em como você gostaria que o coração do seu casamento se parecesse:"},{"text":"\n"},{"text":" ❤ ","color":"dark_red","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} dark_red"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para &4vermelho escuro&r."}},{"text":" ❤ ","color":"red","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} red"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para &cvermelho&r."}},{"text":" ❤ ","color":"gold","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} gold"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para &6dourado&r."}},{"text":" ❤ ","color":"yellow","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} yellow"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para &eamarelo&r."}},{"text":" ❤ ","color":"dark_green","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} dark_green"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para &2verde escuro&r."}},{"text":" ❤ ","color":"green","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} green"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para &averde&r."}},{"text":" ❤ ","color":"aqua","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} aqua"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para &bágua&r."}},{"text":" ❤ ","color":"dark_aqua","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} dark_aqua"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para &3água escura&r."}},{"text":" ❤ ","color":"dark_blue","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} dark_blue"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para &1azul escuro&r."}},{"text":" ❤ ","color":"blue","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} blue"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para &9azul&r."}},{"text":" ❤ ","color":"light_purple","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} light_purple"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para &droxo claro&r."}},{"text":" ❤ ","color":"dark_purple","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} dark_purple"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para &5roxo escuro&r."}},{"text":" ❤ ","color":"white","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} white"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para &fbranco&r."}},{"text":" ❤ ","color":"gray","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} gray"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para &7cinza&r."}},{"text":" ❤ ","color":"dark_gray","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} dark_gary"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para &8cinza escuro&r."}},{"text":" ❤ ","color":"black","clickEvent":{"action":"run_command","value":"/{MainCmdAlias} {SubCmdAlias} black"},"hoverEvent":{"action":"show_text","value":"Define a cor do coração para preto."}}]'
    SetPriest:
      # Placeholders: {Name}, {DisplayName}.    Keep in mind display names contain colors!
      MadeYouAPriest: "{DisplayName}&r&a tornou você um padre."
      YouMadeAPriest: "{DisplayName}&r&a agora é um padre."
      FiredYou: "{DisplayName}&r&c demitiu você como padre."
